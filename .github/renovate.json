{
  "commitMessageAction": "update",
  "commitMessagePrefix": "chore(all): ",
  "extends": [
    "config:base",
    "schedule:weekly",
    ":disableDependencyDashboard"
  ],
  "force": {
    "constraints": {
      "go": "1.25"
    }
  },
  "groupName": "all",
  "ignoreDeps": [
    "google.golang.org/grpc"
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "cloud.google.com/go/pubsub"
      ],
      "matchUpdateTypes": [
        "major"
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "semanticCommits": false
}
